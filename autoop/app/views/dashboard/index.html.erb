<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <div class="mb-8">
    <h1 class="text-2xl font-bold text-gray-900">Dashboard</h1>
    <p class="mt-1 text-sm text-gray-600">Welcome back, <%= current_user.company_name %></p>
  </div>

  <% if @quickbooks_connected %>
    <div class="mb-6 bg-green-50 border border-green-200 rounded-lg p-4 flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-green-800">QuickBooks connected</p>
        <p class="text-xs text-green-700 mt-0.5">Your vendors and GL codes are synced</p>
      </div>
      <div class="flex items-center gap-4">
        <%= button_to "Sync Now", quickbooks_sync_path, method: :post, class: "text-sm font-medium text-white bg-green-600 hover:bg-green-700 px-3 py-1.5 rounded-md" %>
        <%= link_to "Disconnect", quickbooks_disconnect_path, data: { turbo_method: :delete, turbo_confirm: "Disconnect QuickBooks?" }, class: "text-sm text-green-700 underline" %>
      </div>
    </div>
  <% else %>
    <div class="mb-6 bg-amber-50 border border-amber-200 rounded-lg p-4 flex items-center justify-between">
      <div>
        <p class="text-sm font-medium text-amber-800">Connect QuickBooks to get started</p>
        <p class="text-xs text-amber-700 mt-0.5">Sync your vendors and GL codes to enable invoice automation</p>
      </div>
      <%= link_to "Connect now →", quickbooks_connect_path, class: "text-sm font-medium text-amber-800 underline" %>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-5 sm:grid-cols-3 mb-8">
    <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-200">
      <div class="p-5">
        <p class="text-sm font-medium text-gray-500">Total Invoices</p>
        <p class="mt-1 text-3xl font-semibold text-gray-900"><%= @invoices_count %></p>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-200">
      <div class="p-5">
        <p class="text-sm font-medium text-gray-500">Pending Review</p>
        <p class="mt-1 text-3xl font-semibold text-amber-600"><%= @pending_invoices %></p>
      </div>
    </div>
    <div class="bg-white overflow-hidden shadow-sm rounded-lg border border-gray-200">
      <div class="p-5">
        <p class="text-sm font-medium text-gray-500">Vendors Synced</p>
        <p class="mt-1 text-3xl font-semibold text-gray-900"><%= @vendors_count %></p>
      </div>
    </div>
  </div>

  <% if @invoices_count == 0 %>
    <div class="bg-white shadow-sm rounded-lg border border-gray-200 p-12 text-center">
      <p class="text-gray-500 text-sm">No invoices yet.</p>
      <p class="text-gray-400 text-xs mt-1">Forward invoices to your AutoAP email address to get started.</p>
    </div>
  <% end %>
</div>
